# Copy to .env after activate; override for deployment
# BIO_ROOT=/opt/bio_agent
# DELIVERY_ROOT=$BIO_ROOT/rhobind_agent_delivery
# AGENT_DB=$DELIVERY_ROOT/agent_db
# NANOBOT_SRC=$BIO_ROOT/nanobot   # sibling runtime (not the §6.2 overlay)
# NANOBOT_WORKSPACE=$BIO_ROOT/nanobot-bio/workspace
# NANOBOT_CONFIG=$HOME/.nanobot/config.json
# RHOBIND_DEVICE=auto             # auto|cuda|cpu — prefer CUDA in ideal GPU env
