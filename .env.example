# Copy to .env for local overrides (this file is gitignored — never commit secrets)
# BIO_ROOT=/path/to/workspace
# DELIVERY_ROOT=$BIO_ROOT/rhobind_agent_delivery
# AGENT_DB=$DELIVERY_ROOT/agent_db
# NANOBOT_BIO_ROOT=/path/to/nanobot-bio
# NANOBOT_SRC=$NANOBOT_BIO_ROOT/nanobot   # slim in-repo runtime (SoT == runtime)
# NANOBOT_WORKSPACE=$NANOBOT_BIO_ROOT/workspace
# NANOBOT_CONFIG=$HOME/.nanobot/config.json
# NANOBOT_TOOL_ALLOW=rbp                   # ToolLoader allowlist (default rbp)
# RHOBIND_DEVICE=auto             # auto|cuda|cpu — prefer CUDA when available
# CONDA_ENVS_PATH=/path/to/conda/envs   # if envs are not under ~/miniconda3/envs
# HF_ENDPOINT=https://hf-mirror.com   # optional China mirror for ESM weights
# OMP_NUM_THREADS=4                   # keep small for science conda tools
